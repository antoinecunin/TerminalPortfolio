# TEMPLATE DE CONFIGURATION - COPIER VERS .env ET .env.dev
# =============================================================

# Variables communes
# Formats de log Morgan : 'dev' (développement), 'combined' (production), 'common', 'short', 'tiny'
API_HEALTH_PATH=/api/health
MONGO_RETRY_MS=2000
MONGO_MAX_RETRIES=60
S3_REGION=garage
S3_ACCESS_KEY=GK1234567890abcdef1234
S3_SECRET_KEY=abcdef1234567890abcdef1234567890abcdef12
S3_USE_SSL=false
GARAGE_ADMIN_TOKEN=annales-garage-admin-token

# Variables spécifiques à l'environnement
API_PORT=3000
WEB_PORT=8080
VITE_PORT=5173
MONGO_PORT=27017
MONGO_EXTERNAL_PORT=27017
GARAGE_S3_EXTERNAL_PORT=3900
GARAGE_ADMIN_EXTERNAL_PORT=3903
API_EXTERNAL_PORT=3000
CORS_ORIGIN=http://localhost:8080,http://localhost:5173
MONGO_URI=mongodb://mongo:27017/annales
S3_ENDPOINT=garage:3900
S3_BUCKET=annales
NODE_ENV=production
API_LOG_LEVEL=combined

# Variables d'authentification - À CONFIGURER OBLIGATOIREMENT
JWT_SECRET=CHANGEZ_MOI_CLÉ_SECRÈTE_TRÈS_LONGUE_ET_ALÉATOIRE
JWT_EXPIRES_IN=7d
FRONTEND_URL=http://localhost:8080

# Variables email/SMTP - À CONFIGURER OBLIGATOIREMENT
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=VOTRE_UTILISATEUR_SMTP
SMTP_PASS=VOTRE_MOT_DE_PASSE_SMTP
EMAIL_FROM_NAME="Annales - Unistra"
EMAIL_FROM_ADDRESS=VOTRE_EMAIL_EXPEDITEUR

# Premier utilisateur admin - FACULTATIF (création automatique au démarrage)
# Si ces variables sont définies ET qu'aucun admin n'existe, un admin sera créé automatiquement
INITIAL_ADMIN_EMAIL=admin@etu.unistra.fr
INITIAL_ADMIN_PASSWORD=CHANGEZ_MOI_MOT_DE_PASSE_ADMIN
INITIAL_ADMIN_FIRSTNAME=Admin
INITIAL_ADMIN_LASTNAME=System

# INSTRUCTIONS DE CONFIGURATION:
# ==============================
# 1. Copiez ce fichier vers .env (production) et .env.dev (développement)
# 2. Changez OBLIGATOIREMENT:
#    - JWT_SECRET: générez une clé secrète très longue et aléatoire
#    - SMTP_USER: votre identifiant SMTP Brevo
#    - SMTP_PASS: votre mot de passe SMTP Brevo
#    - EMAIL_FROM_ADDRESS: votre adresse email d'expéditeur
#    - FRONTEND_URL: l'URL de votre frontend
#    - INITIAL_ADMIN_PASSWORD: mot de passe du premier admin (en production)
# 3. Ajustez les autres variables selon votre environnement
#
# PREMIER ADMIN:
# ==============
# - En production, définissez les variables INITIAL_ADMIN_* pour créer automatiquement
#   le premier utilisateur admin au démarrage de l'API
# - L'admin sera créé uniquement s'il n'existe aucun admin dans la base
# - Une fois créé, vous pouvez supprimer ces variables de .env pour plus de sécurité
#
# SÉCURITÉ:
# =========
# - Ne committez JAMAIS les fichiers .env dans git
# - Utilisez des mots de passe forts et uniques
# - Changez les clés par défaut en production