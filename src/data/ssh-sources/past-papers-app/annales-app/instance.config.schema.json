{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Instance Configuration",
  "description": "Configuration for instance customization",
  "type": "object",
  "required": ["instance", "email"],
  "properties": {
    "instance": {
      "type": "object",
      "description": "Instance information and GDPR required fields",
      "required": ["name", "organizationName", "contactEmail"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Instance name displayed in the app (keep it short)",
          "minLength": 1,
          "examples": ["Exam Archive - My University"]
        },
        "organizationName": {
          "type": "string",
          "description": "Name of the organization managing this instance (GDPR required)",
          "minLength": 1,
          "examples": ["My University"]
        },
        "contactEmail": {
          "type": "string",
          "format": "email",
          "description": "Contact email for GDPR requests and support",
          "examples": ["contact@example.com"]
        }
      }
    },
    "email": {
      "type": "object",
      "description": "Email validation settings",
      "required": ["allowedDomains"],
      "properties": {
        "allowedDomains": {
          "type": "array",
          "description": "Email domains allowed for registration (e.g., @students.example.edu)",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^@[\\w.-]+\\.\\w+$",
            "examples": ["@students.example.edu", "@university.edu"]
          }
        }
      }
    }
  }
}
